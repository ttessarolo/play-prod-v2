  "type": "endpoint-in",
  "execute": "    // **********************************************************\n    // @description Generate userID from Payload \n    //\n    // @param   {object} data - payload\n    // @param   {object} $    - {tenant, paramsId, endpointId, endpointConfig}\n    // @param   {object} ctx  - opentracing context\n    // @param   {object} this - ARES\n    //\n    // @return  {object} data - payload decorated\n    // **********************************************************\n    \n    if(data.query && data.query.userId && data.query.personaShortId && !data.query.originalUserId){\n      data.query.familyId = data.query.userId;\n      data.query.userId = `${data.query.userId}:${decodeURIComponent(data.query.personaShortId)}`;\n      //data.query.infinityClusterId = await this.cache.getObjectKey({object: `{cluster:infinity:play-prod-v2}`, key: data.query.userId, ctx});\n      //data.query.freeClusterId = await this.cache.getObjectKey({object: `{cluster:free:play-prod-v2}`, key: data.query.userId, ctx})\n    }\n    \n    return data;",
